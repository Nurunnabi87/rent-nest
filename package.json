{
  "name": "rentnest",
  "version": "1.0.0",
  "description": "RentNest - Backend API for a rental property marketplace. Find & List Rental Properties with Ease.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "seed": "tsx prisma/seed.ts"
